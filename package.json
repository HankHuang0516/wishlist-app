{
  "name": "wishlist-app-root",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix client && npm install --prefix server",
    "build": "npm run build --prefix client && npm run build --prefix server",
    "start": "npm start --prefix server",
    "test": "npm run test --prefix client",
    "test:watch": "npm run test -- --watch --prefix client",
    "smoke-test": "node scripts/smoke-test.js",
    "smoke-test:prod": "node scripts/smoke-test.js --prod",
    "regression": "node scripts/regression-test.js",
    "regression:quick": "node scripts/regression-test.js --quick"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.0",
    "@types/nodemailer": "^7.0.9",
    "puppeteer": "^24.36.1"
  },
  "dependencies": {
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
